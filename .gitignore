# 课程压缩包（解压后使用 NER/ 即可，一般不必提交 rar）
NER.rar

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/

# ---- 运行生成物（体积大、可再跑脚本生成；服务器跑完用 scp/rsync 拉回本地）----
NER/predictions/
_eval_preds/
task1_hmm/models/
task2_crf/models/
task3_transformer_crf/checkpoints/
task3_transformer_crf/checkpoints_bert/

# 根目录面试/本地一键评测输出
*_pred_task*.txt
English_pred_*.txt
Chinese_pred_*.txt

# 本地 test 目录：仅保留说明，不提交从 validation 复制的 test.txt
test/**/test.txt

# HuggingFace / 误生成的缓存目录（Windows 下 %CD% 未展开时会出现）
.cache/
%CD%/
.huggingface/

# 模型/中间件通用后缀（防止误提交到子目录）
*.pt
# 报告打包：pj2/part3 内提交的 Transformer+CRF 权重复本需纳入版本库
!pj2/part3/checkpoints/
!pj2/part3/checkpoints/*.pt
*.npz
*.pkl

# 提交包、大文件
*.zip
pj2/report.pdf

